{
  "name": "saas-starter-kit",
  "version": "1.6.0",
  "private": true,
  "prisma": {
    "seed": "ts-node ./prisma/seed.ts"
  },
  "scripts": {
    "release": "git checkout release && git merge origin/main && release-it && git checkout main && git merge origin/release && git push origin main",
    "dev": "next dev --port 4002",
    "build": "prisma generate && prisma db push && next build --webpack",
    "start": "next start --port 4002",
    "check-types": "next typegen && tsc --pretty --noEmit",
    "check-format": "prettier --check .",
    "check-lint": "eslint -c eslint.config.cjs ./",
    "check-unused": "npx knip",
    "format": "prettier --write .",
    "test-all": "npm run check-format && npm run check-lint && npm run check-types && npm run build",
    "playwright:update": "playwright install && playwright install-deps",
    "test:e2e": "playwright test -x",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --env=jsdom",
    "build-ci": "prisma generate && next build --webpack",
    "sync-stripe": "node --env-file .env sync-stripe.js",
    "check-locale": "node check-locale.js",
    "delete-team": "node --env-file .env delete-team.js"
  },
  "dependencies": {
    "@boxyhq/metrics": "0.2.12",
    "@boxyhq/react-ui": "3.5.3",
    "@boxyhq/saml-jackson": "26.2.0",
    "@heroicons/react": "2.2.0",
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@retracedhq/logs-viewer": "2.10.1",
    "@retracedhq/retraced": "0.7.23",
    "@sentry/nextjs": "^10.57.0",
    "@tailwindcss/typography": "0.5.19",
    "bcryptjs": "3.0.3",
    "classnames": "2.5.1",
    "cookies-next": "6.1.1",
    "currency-symbol-map": "5.1.0",
    "formik": "2.4.9",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "micromatch": "4.0.8",
    "mixpanel-browser": "2.80.0",
    "next": "16.2.9",
    "next-auth": "4.24.14",
    "next-i18next": "^16.0.7",
    "next-themes": "^0.4.6",
    "nodemailer": "7.0.11",
    "pg": "^8.21.0",
    "react": "19.2.7",
    "react-daisyui": "5.0.5",
    "react-dom": "19.2.7",
    "react-email": "^6.6.0",
    "react-google-recaptcha": "3.1.0",
    "react-hot-toast": "2.6.0",
    "react-i18next": "^17.0.8",
    "sharp": "0.34.5",
    "slack-notify": "2.0.7",
    "stripe": "^22.2.1",
    "svix": "1.89.0",
    "swr": "2.4.1",
    "yup": "1.7.1",
    "zod": "3.25.64"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.9.1",
    "@types/jest": "30.0.0",
    "@types/micromatch": "4.0.10",
    "@types/mixpanel-browser": "2.66.0",
    "@types/node": "25.6.2",
    "@types/nodemailer": "7.0.4",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "autoprefixer": "10.4.27",
    "daisyui": "4.12.24",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-i18next": "6.1.4",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "^7.8.0",
    "release-it": "20.2.0",
    "tailwindcss": "3.4.17",
    "ts-node": "10.9.2",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "typeorm": {
      "mssql": ">=11.0.0"
    },
    "react-email": {
      "esbuild": ">=0.25.0",
      "next": ">=15.2.3"
    },
    "@react-email/components": {
      "prismjs": ">=1.30.0"
    },
    "@types/react": "19.2.17",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "eslint-plugin-react": "7.35.0"
  }
}
